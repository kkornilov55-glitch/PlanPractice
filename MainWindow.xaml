<Window x:Name="PlanPracticeUI" x:Class="PlanPractice.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Plan.UI"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Database Manager" Height="450" Width="800" Icon="/data-server_9698555.png">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1" Grid.Column="1"
                Background="#F5F5F7"
                BorderBrush="#E0E0E0"
                BorderThickness="1.7"
                Padding="15,10"
                CornerRadius="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text ="Подключение:" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="14" FontWeight="SemiBold"/>
                <Grid VerticalAlignment="Center" Margin="0,0,10,0" Width="180" Height="25">

                    <Border CornerRadius="4" Background="White">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="3" Direction="270" Opacity="0.30" Color="Black" />
                        </Border.Effect>
                    </Border>

                    <Border BorderBrush="#CCCCCC" BorderThickness="1" 
                            CornerRadius="4" Background="White">
                        <TextBox x:Name="DataBaseName_TextBox" 
                                 VerticalAlignment="Center" Width="170" 
                                 IsReadOnly="True" Height="18" 
                                 Margin="-4,0,-4,0" BorderThickness="0" FontSize="12" Style="{x:Null}"/>
                    </Border>
                </Grid>
                <Grid Width="140" Height="25">

                    <Border Background="#007ACC" CornerRadius="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="3" Direction="270" Opacity="0.30" Color="#FF0300FF" />
                        </Border.Effect>
                    </Border>

                    <Button x:Name="Connect_Button" 
                            Style="{StaticResource RoundedButton}" 
                            Background="#007ACC" 
                            Foreground="White" 
                            Click="Connect_Button_Click">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LinkVariant" Width="20" Height="20" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Подключиться" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        </StackPanel>

                    </Button>

                </Grid>
            </StackPanel>
        </Border>
        <Grid Grid.Row="3" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="225"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FAFAFA"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1.7"
                    CornerRadius="6">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderHouse" Height="16" Width="16" Margin="5,7,5,0"/>
                        <TextBlock Text="Таблицы" VerticalAlignment="Center" Margin="2,8,0,6" FontFamily="Segoe UI Semibold" />
                    </StackPanel>
                    <TreeView x:Name="TablesTreeView"
                              ItemsSource="{Binding TableNames}"
                              BorderThickness="0" 
                              Background="Transparent" 
                              SelectedItemChanged="TablesTreeView_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0.5">
                                    <materialDesign:PackIcon Kind="Table" Height="16" Width="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </StackPanel>
            </Border>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FAFAFA"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1.7"
                        CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name ="AddRow_Button"  Margin="10,0,5,0" Background="#FAFAFA" BorderThickness="0" Visibility="Hidden" Click="AddRow_Button_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Add" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Добавить запись"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="#FAFAFA"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1.7"
                        CornerRadius="6">
                    <DataGrid x:Name="MainDataGrid" 
                              Style="{StaticResource MaterialDesignDataGrid}"
                              AutoGenerateColumns="True" 
                              IsReadOnly="True"
          
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserReorderColumns="False"
          
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E0E0E0"
                              BorderThickness="0"
                              Background="White"
          
                              AlternatingRowBackground="#F8F9FA"
                              RowHeight="35"
                              ColumnWidth="*">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">

                                <Setter Property="Background" Value="#EEEEEE" />

                                <Setter Property="Foreground" Value="#333333" />

                                <Setter Property="FontWeight" Value="SemiBold" />

                                <Setter Property="Padding" Value="10,8" />

                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
